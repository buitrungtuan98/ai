# ─────────────────────────────────────────────────────────────────────────────
# AI Video Factory — environment template.
# Copy to .env and fill in. NEVER commit the real .env.  chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# --- Core mode -------------------------------------------------------------
# false = solo dogfood (no Firebase, one built-in admin). true = public + Firebase SSO.
MULTI_TENANT_MODE=false

# --- Encryption (REQUIRED) -------------------------------------------------
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separate to rotate (new key first): FERNET_KEY=newkey,oldkey
# BACK THIS UP OFFLINE. Losing it makes every stored credential unrecoverable.
FERNET_KEY=

# --- Datastore -------------------------------------------------------------
# Absolute path inside the container (shared volume). Do not point at a networked FS.
DATABASE_URL=sqlite:////data/db/factory.db
REDIS_URL=redis://redis:6379/0

# --- Filesystem paths ------------------------------------------------------
MEDIA_ROOT=/data/media          # render scratch + buffer-pool videos
WORK_ROOT=/data/media/work      # per-job workspaces (auto-cleaned)

# --- Google OAuth2 (YouTube channel connect + upload) ----------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL Cloudflare serves; used as the OAuth redirect base.
OAUTH_REDIRECT_BASE=https://factory.example.com

# --- Firebase (only needed when MULTI_TENANT_MODE=true) --------------------
FIREBASE_CREDENTIALS_PATH=config/firebase_credentials.json
# Public Web API Key (Firebase console -> Project settings -> General). Used by the /login page
# for email/password sign-in via the Firebase Auth REST API. Public identifier, not a secret.
FIREBASE_WEB_API_KEY=

# --- Browser sessions (multi-tenant login) ----------------------------------
# Signs the session cookie. REQUIRED in production: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_MAX_AGE_DAYS=7

# --- Optional global fallback API keys -------------------------------------
# Per-user keys entered in the dashboard take priority; these are optional fallbacks.
GEMINI_API_KEY=
PEXELS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Cloudflare Tunnel -----------------------------------------------------
# Tunnel token from the Cloudflare Zero-Trust dashboard. Grants full tunnel control — secret.
TUNNEL_TOKEN=

# --- Backups ---------------------------------------------------------------
# Fine-grained PAT scoped to the private backups repo, contents:write, with an expiry.
GITHUB_PAT=
BACKUP_REPO=buitrungtuan98/ai-video-factory-backups
BACKUP_BRANCH=main

# --- Rendering tuning ------------------------------------------------------
FFMPEG_THREADS=4
FFMPEG_NICE=19
FFMPEG_PRESET=veryfast
DEFAULT_BUFFER_SIZE=3           # pre-rendered episodes kept ready per active campaign
JOB_TIMEOUT_SECONDS=2700        # 45 min hard cap per render job
ORPHAN_MAX_AGE_MINUTES=60       # temp media never lingers longer than this

# --- Scheduler / automation tick -------------------------------------------
TIMEZONE=UTC                    # IANA name (e.g. Asia/Ho_Chi_Minh) — posting slots use this timezone
SCHEDULER_INTERVAL_SECONDS=3600 # how often the in-process tick runs (hourly)
SLOT_TOLERANCE_MINUTES=30       # how close to a posting slot counts as "now"
BUFFER_MAX_AGE_HOURS=72         # expire pre-rendered buffer items older than this
DISK_PRESSURE_PCT=90            # sweep temp media aggressively above this disk usage

# --- App ------------------------------------------------------------------
LOG_LEVEL=INFO
